# AchaeanFleet Docker Compose Environment Variables
# Copy this to .env and fill in secrets before running.
# NEVER commit .env to version control.

# =============================================================================
# AI Maestro Connection
# =============================================================================
# URL where ai-maestro is running (the orchestrator)
AIM_HOST=http://172.20.0.1:23000

# =============================================================================
# Agent API Keys (pass only what each agent needs)
# =============================================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# For Aider (supports multiple providers):
AIDER_MODEL=claude-3-5-sonnet-20241022

# =============================================================================
# Image Tags
# =============================================================================
# Override to pin specific image versions
CLAUDE_IMAGE=achaean-claude:latest
CODEX_IMAGE=achaean-codex:latest
AIDER_IMAGE=achaean-aider:latest
GOOSE_IMAGE=achaean-goose:latest
CLINE_IMAGE=achaean-cline:latest
OPENCODE_IMAGE=achaean-opencode:latest
CODEBUFF_IMAGE=achaean-codebuff:latest
AMPCODE_IMAGE=achaean-ampcode:latest
WORKER_IMAGE=achaean-worker:latest

# =============================================================================
# Host workspace mounts
# =============================================================================
# Absolute path to mount as /workspace inside containers
# Each agent can have its own working directory
WORKSPACE_ROOT=/home/mvillmow

# Path to agent-server.js on the host (mounted read-only into containers)
# Change this if ai-maestro is installed in a non-default location.
AGENT_SERVER_JS=/home/mvillmow/ai-maestro/agent-container/agent-server.js

# =============================================================================
# Network
# =============================================================================
MESH_NETWORK=aimaestro-mesh
