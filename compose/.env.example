# AchaeanFleet Docker Compose Environment Variables
# Copy this to .env and fill in secrets before running.
# NEVER commit .env to version control.

# =============================================================================
# ProjectAgamemnon Connection
# =============================================================================
# Agents connect to Caddy (TLS terminator) instead of Agamemnon directly.
# Run: bash ../tls/generate-certs.sh  before starting the mesh.
# Use docker-compose.caddy.yml overlay to start the Caddy service.
AGAMEMNON_URL=https://caddy:8443

# URL that Caddy forwards to (plain HTTP to host-side Agamemnon)
AGAMEMNON_HOST_URL=http://172.20.0.1:8080

# =============================================================================
# TLS Configuration
# =============================================================================
# Directory containing certs generated by tls/generate-certs.sh
TLS_CERT_DIR=../tls/certs
# CA certificate mounted at /certs/ca.crt inside each container
TLS_CA_CERT=/certs/ca.crt

# =============================================================================
# NATS (forward-looking — required when Hermes/Keystone are integrated)
# =============================================================================
NATS_URL=tls://nats:4222

# =============================================================================
# Agent API Keys
# =============================================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AIDER_MODEL=claude-3-5-sonnet-20241022

# =============================================================================
# Image Tags
# =============================================================================
CLAUDE_IMAGE=achaean-claude:latest
CODEX_IMAGE=achaean-codex:latest
AIDER_IMAGE=achaean-aider:latest
GOOSE_IMAGE=achaean-goose:latest
CLINE_IMAGE=achaean-cline:latest
OPENCODE_IMAGE=achaean-opencode:latest
CODEBUFF_IMAGE=achaean-codebuff:latest
AMPCODE_IMAGE=achaean-ampcode:latest
WORKER_IMAGE=achaean-worker:latest

# =============================================================================
# Host workspace mounts
# =============================================================================
WORKSPACE_ROOT=/home/mvillmow

# =============================================================================
# Network
# =============================================================================
MESH_NETWORK=homeric-mesh
