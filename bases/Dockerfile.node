# AchaeanFleet Base Image: Node.js
#
# Provides: node:20-slim + tmux + zsh + git
# Compatible with the HomericIntelligence agent mesh.
# All node-based agent vessels (Claude, Codex, Cline, Codebuff, AmpCode) FROM this.

FROM node:20-slim

LABEL org.opencontainers.image.title="achaean-base-node"
LABEL org.opencontainers.image.description="AchaeanFleet Node.js base image for AI agent containers"
LABEL org.opencontainers.image.source="https://github.com/HomericIntelligence/AchaeanFleet"

USER root

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    git \
    tmux \
    zsh \
    vim \
    nano \
    procps \
    ca-certificates \
    build-essential \
    python3 \
    sudo \
    && rm -rf /var/lib/apt/lists/*

# node:20-slim ships with user 'node' (UID 1000). Rename to 'agent' for convention.
RUN usermod -l agent -d /home/agent -m node && \
    groupmod -n agent node && \
    echo "agent ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# Shared agent environment setup (tmux config, Oh My Zsh, workspace dirs)
COPY scripts/setup-agent-env.sh /tmp/setup-agent-env.sh
RUN chmod +x /tmp/setup-agent-env.sh && /tmp/setup-agent-env.sh && rm /tmp/setup-agent-env.sh

WORKDIR /workspace

ENV AGENT_ID=agent-local
ENV TMUX_SESSION_NAME=agent-session
ENV WORKSPACE=/workspace
ENV AGENT_PORT=23001
ENV GIT_USER_NAME="HomericIntelligence Agent"
ENV GIT_USER_EMAIL="agent@HomericIntelligence.ai"

USER agent
