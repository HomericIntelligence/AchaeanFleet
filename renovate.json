{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "pinDigests": true,
  "schedule": ["every week"],
  "packageRules": [
    {
      "matchManagers": ["dockerfile"],
      "matchFileNames": ["bases/Dockerfile.*"],
      "enabled": true,
      "groupName": "base image digests"
    },
    {
      "matchManagers": ["github-actions"],
      "enabled": true,
      "groupName": "github actions"
    }
  ]
}
